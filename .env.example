# PolyClaw Configuration

# API Base URLs (defaults shown — override only if needed)
# POLYCLAW_GAMMA_BASE_URL=https://gamma-api.polymarket.com
# POLYCLAW_CLOB_BASE_URL=https://clob.polymarket.com
# POLYCLAW_DATA_BASE_URL=https://data-api.polymarket.com

# Pagination
# POLYCLAW_GAMMA_PAGE_SIZE=100
# POLYCLAW_CLOB_BATCH_SIZE=50

# Refresh intervals (seconds)
# POLYCLAW_MARKET_REFRESH_INTERVAL=600
# POLYCLAW_PRICE_REFRESH_INTERVAL=60

# Database
# POLYCLAW_DB_PATH=polyclaw.db

# Trading mode: "paper" (simulated) or "live" (real money)
POLYCLAW_TRADING_MODE=paper

# Paper trading config
# POLYCLAW_PAPER_DB_PATH=paper_trading.db
# POLYCLAW_PAPER_STARTING_BALANCE=10000.0

# Database backend: "sqlite" (local dev) or "supabase" (production / Vercel)
POLYCLAW_DB_BACKEND=sqlite

# Supabase (required when DB_BACKEND=supabase)
# POLYCLAW_SUPABASE_URL=https://xxxxx.supabase.co
# POLYCLAW_SUPABASE_KEY=your-anon-key

# Live trading authentication (only needed for POLYCLAW_TRADING_MODE=live)
# Step 1: Set your Polygon EOA private key
# POLYCLAW_PRIVATE_KEY=0x...
#
# Step 2: After running `polyclaw setup-live`, store the derived credentials:
# POLYCLAW_API_KEY=...
# POLYCLAW_API_SECRET=...
# POLYCLAW_API_PASSPHRASE=...
