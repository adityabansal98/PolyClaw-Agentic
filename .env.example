# PolyClaw Configuration
# Copy this file to .env and fill in the values you need.

# ─────────────────────────────────────────────────────────────────────────
# Runtime mode
# ─────────────────────────────────────────────────────────────────────────

# "development" (default), "test", or "production"
# Production mode rejects ephemeral SQLite paths and requires Postgres.
POLYCLAW_ENV=development

# Trading mode: "paper" (simulated) or "live" (real money via Polymarket CLOB)
POLYCLAW_TRADING_MODE=paper

# Logging
# POLYCLAW_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────────────────
# Database backend
# ─────────────────────────────────────────────────────────────────────────

# "sqlite" (local dev) or "postgres" / "supabase" (production)
POLYCLAW_DB_BACKEND=sqlite

# SQLite path (relative or absolute). Defaults to paper_trading.db at repo root.
# POLYCLAW_PAPER_DB_PATH=paper_trading.db
# POLYCLAW_DB_PATH=polyclaw.db

# Postgres / Supabase connection (required when DB_BACKEND=postgres or supabase)
# POLYCLAW_DATABASE_URL=postgresql://user:pass@host:5432/polyclaw
# POLYCLAW_SUPABASE_URL=https://xxxxx.supabase.co
# POLYCLAW_SUPABASE_KEY=your-anon-key

# ─────────────────────────────────────────────────────────────────────────
# Paper trading
# ─────────────────────────────────────────────────────────────────────────

# POLYCLAW_PAPER_STARTING_BALANCE=10000.0

# ─────────────────────────────────────────────────────────────────────────
# Polymarket API endpoints (defaults shown — override only if needed)
# ─────────────────────────────────────────────────────────────────────────

# POLYCLAW_GAMMA_BASE_URL=https://gamma-api.polymarket.com
# POLYCLAW_CLOB_BASE_URL=https://clob.polymarket.com
# POLYCLAW_DATA_BASE_URL=https://data-api.polymarket.com

# Pagination + refresh intervals
# POLYCLAW_GAMMA_PAGE_SIZE=100
# POLYCLAW_CLOB_BATCH_SIZE=50
# POLYCLAW_MARKET_REFRESH_INTERVAL=600
# POLYCLAW_PRICE_REFRESH_INTERVAL=60

# ─────────────────────────────────────────────────────────────────────────
# Live trading authentication (only required for POLYCLAW_TRADING_MODE=live)
# ─────────────────────────────────────────────────────────────────────────

# Step 1: Set your Polygon EOA private key
# POLYCLAW_PRIVATE_KEY=0x...
#
# Step 2: After running `polyclaw setup-live`, store the derived credentials:
# POLYCLAW_API_KEY=...
# POLYCLAW_API_SECRET=...
# POLYCLAW_API_PASSPHRASE=...

# ─────────────────────────────────────────────────────────────────────────
# MCP server (Claude Desktop / Cursor)
# ─────────────────────────────────────────────────────────────────────────

# POLYCLAW_MCP_BASE_URL=http://localhost:5000
# POLYCLAW_MCP_BEARER_TOKEN=polyclaw_live_...

# ─────────────────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────────────────

# Bypass SSL verification for local Postgres (NEVER set in production)
# POLYCLAW_ALLOW_INSECURE_SSL=false
